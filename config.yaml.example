# LavenderCode Configuration
providers:
  - protocol: anthropic          # Options: anthropic, openai
    model: claude-sonnet-4-20250514
    base_url: https://api.anthropic.com
    api_key: your-api-key-here
    thinking:
      enabled: false
      budget_tokens: 4000
    context_window: 200000   # optional; omit for protocol default

options:
  max_tokens: 4096
  system_prompt: "You are a helpful AI assistant."
  tool_system_enabled: true
  command_execution_enabled: false
  command_timeout_seconds: 120
  file_operation_timeout_seconds: 30
  read_file_max_lines: 2000
  command_output_max_chars: 30000
  search_max_results: 200
  enable_sub_agent_background: true
